---
import { services } from '~/data/site';

const icons: Record<string, string> = {
  scan: 'M4 7h3V4M20 7h-3V4M4 17h3v3M20 17h-3v3M9 12h6',
  fuel: 'M5 21V5a2 2 0 012-2h6a2 2 0 012 2v16M5 21h10M5 13h10M15 9h2a2 2 0 012 2v6a2 2 0 002 2',
  turbo: 'M12 4v4M12 16v4M4 12h4M16 12h4M6.3 6.3l2.8 2.8M14.9 14.9l2.8 2.8M17.7 6.3l-2.8 2.8M9.1 14.9l-2.8 2.8',
  engine: 'M5 9h2V7h4V5h2v2h4v2h2v6h-2v2h-4v2h-2v-2H7v-2H5z',
  brake: 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 4a5 5 0 110 10 5 5 0 010-10zM12 12v.01',
  shield: 'M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z',
};
---
<section id="servicios" class="py-20 bg-white">
  <div class="container-x">
    <div class="max-w-2xl">
      <div class="eyebrow">Nuestros servicios</div>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">Servicios preventivos y correctivos para unidades diésel.</h2>
      <p class="mt-4 text-[var(--color-text-muted)]">Mecánica general especializada en diésel — motor, suspensión y frenos. Programamos preventivos para evitar paros y resolvemos correctivos cuando se necesitan.</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((s) => (
        <div class="group rounded-xl border border-[var(--color-border)] bg-white p-6 hover:border-[var(--color-mj-green)] hover:shadow-md transition">
          <div class="w-12 h-12 rounded-lg bg-[var(--color-mj-green)]/10 text-[var(--color-mj-green-dark)] flex items-center justify-center group-hover:bg-[var(--color-mj-green)] group-hover:text-white transition">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={icons[s.icon] ?? icons.shield} />
            </svg>
          </div>
          <h3 class="mt-5 font-display text-lg font-bold text-[var(--color-navy)]">{s.title}</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">{s.blurb}</p>
        </div>
      ))}
    </div>
  </div>
</section>
