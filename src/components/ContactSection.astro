---
import { site } from '~/data/site';
const waUrl = `https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}?text=${encodeURIComponent('Hola, me gustaría agendar una cita en Micro Diesel de Mérida.')}`;
const fullAddr = `${site.address.street}, ${site.address.colonia}, ${site.address.postalCode} ${site.address.city}, ${site.address.region}`;
const mapsQuery = encodeURIComponent(`${site.brand} ${fullAddr}`);
---
<section id="contacto" class="py-20 bg-white">
  <div class="container-x grid gap-12 lg:grid-cols-2">
    <div>
      <div class="eyebrow">Contacto</div>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">¿Listo para revisar tu diésel?</h2>
      <p class="mt-4 text-[var(--color-text-muted)]">Agenda tu cita por WhatsApp o llámanos. Atendemos flotillas y unidades particulares de lunes a viernes; sábados con cita previa.</p>

      <div class="mt-8 space-y-5 text-sm">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-mj-green)]/10 text-[var(--color-mj-green-dark)] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a8 8 0 00-8 8c0 5.5 8 12 8 12s8-6.5 8-12a8 8 0 00-8-8zm0 11a3 3 0 110-6 3 3 0 010 6z"/></svg>
          </div>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Dirección</div>
            <div class="text-[var(--color-text-muted)]">{site.address.street}<br/>{site.address.colonia}<br/>CP {site.address.postalCode} · {site.address.city}, {site.address.region}</div>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-mj-green)]/10 text-[var(--color-mj-green-dark)] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
          </div>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Teléfono</div>
            <div><a href={`tel:${site.phoneE164}`} class="text-[var(--color-mj-green-dark)] hover:underline">{site.phone}</a></div>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-mj-green)]/10 text-[var(--color-mj-green-dark)] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </div>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Horario</div>
            <div class="text-[var(--color-text-muted)]">{site.hours}</div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={waUrl} target="_blank" rel="noopener" class="btn-primary">WhatsApp directo</a>
        <a href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold border border-[var(--color-border)] text-[var(--color-navy)] hover:bg-[var(--color-surface-alt)]">
          Cómo llegar
        </a>
      </div>
    </div>

    <div class="rounded-2xl overflow-hidden border border-[var(--color-border)] min-h-[360px] bg-[var(--color-surface-alt)]">
      <iframe
        title="Mapa Micro Diesel de Mérida"
        class="w-full h-full min-h-[360px]"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src={`https://www.google.com/maps?q=${mapsQuery}&output=embed`}
      ></iframe>
    </div>
  </div>
</section>
