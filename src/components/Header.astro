---
import { nav, site } from '~/data/site';
import Logo from './Logo.astro';
---
<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-[var(--color-border)]">
  <div class="container-x flex items-center justify-between gap-6 h-20">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <Logo class="h-12 w-12" />
      <div class="hidden sm:block leading-tight">
        <div class="font-display text-base md:text-lg font-extrabold text-[var(--color-navy)] tracking-tight">MICRO DIESEL</div>
        <div class="text-[11px] font-semibold tracking-[0.18em] text-[var(--color-mj-green-dark)]">DE MÉRIDA</div>
      </div>
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-[var(--color-text)]">
      {nav.map((item) => (
        <a href={item.href} class="hover:text-[var(--color-mj-green-dark)] transition">{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a href={`https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener" class="btn-primary text-sm hidden md:inline-flex">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 003.4 17.3L2 22l4.8-1.4A11 11 0 1020.5 3.5zM12 20.1a8.1 8.1 0 01-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8.1 8.1 0 1112 20.1zm4.7-6.1c-.3-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.7.8-.8 1-.3.1-.6 0a6.6 6.6 0 01-3.3-2.9c-.2-.4 0-.4.2-.6s.3-.3.5-.5.2-.3.3-.5 0-.4 0-.5-.6-1.5-.9-2.1-.5-.5-.6-.5h-.5a1 1 0 00-.7.3 3 3 0 00-1 2.3c0 1.4 1 2.7 1.2 2.9s2 3 4.8 4.2a16.4 16.4 0 001.6.6 3.8 3.8 0 001.7.1 2.8 2.8 0 001.9-1.3 2.4 2.4 0 00.2-1.3c-.1-.2-.3-.3-.6-.4z"/></svg>
        WhatsApp
      </a>
      <a href={`tel:${site.phoneE164}`} class="hidden md:flex items-center gap-2 text-sm font-semibold text-[var(--color-navy)] hover:text-[var(--color-mj-green-dark)]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
        {site.phone}
      </a>
      <button id="mobile-menu-toggle" class="lg:hidden p-2" aria-label="Abrir menú">
        <svg class="w-6 h-6 text-[var(--color-navy)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-white">
    <nav class="container-x py-4 flex flex-col gap-1">
      {nav.map((item) => (
        <a href={item.href} class="py-2.5 px-3 rounded font-medium hover:bg-[var(--color-surface-alt)]">{item.label}</a>
      ))}
      <a href={`https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener" class="btn-primary mt-3 justify-center">WhatsApp</a>
      <a href={`tel:${site.phoneE164}`} class="text-center py-3 font-semibold text-[var(--color-navy)]">📞 {site.phone}</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
