---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import StatBar from '~/components/StatBar.astro';
import ServicesGrid from '~/components/ServicesGrid.astro';
import AboutSection from '~/components/AboutSection.astro';
import ContactSection from '~/components/ContactSection.astro';
import { site } from '~/data/site';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['AutoRepair', 'LocalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.legalName,
  alternateName: site.short,
  url: site.url,
  logo: `${site.url}/logo-mj-merida.jpg`,
  image: `${site.url}/logo-mj-merida.jpg`,
  description: 'Taller mecánico especializado en motores diésel en Mérida, Yucatán. Diagnóstico computarizado, inyección, turbos y reparación de motor.',
  telephone: site.phoneE164,
  email: site.email,
  founder: { '@type': 'Person', name: site.owner },
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  openingHours: site.hoursSchema,
  areaServed: [
    { '@type': 'City', name: 'Mérida' },
    { '@type': 'State', name: 'Yucatán' },
  ],
  priceRange: '$$',
  slogan: site.tagline,
  knowsAbout: [
    'Motor diésel',
    'Inyección common-rail',
    'Turbocompresores',
    'Diagnóstico computarizado',
    'Reparación de motor',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site.url}#website`,
  url: site.url,
  name: site.brand,
  publisher: { '@id': `${site.url}#organization` },
  inLanguage: 'es-MX',
};
---
<BaseLayout
  title={`${site.brand} | Taller especialista en diésel en Mérida, Yucatán`}
  description="Micro Diesel de Mérida — taller mecánico especializado en motores diésel en Mérida, Yucatán. Diagnóstico computarizado, inyección, turbos, reparación de motor y mantenimiento preventivo."
  schema={[orgSchema, websiteSchema]}
>
  <Hero />
  <StatBar />
  <ServicesGrid />
  <AboutSection />
  <ContactSection />
</BaseLayout>
